# ─────────────────────────────────────────────────────────────
# Synapse environment configuration (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development

# --- Postgres (pgvector) ---
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
POSTGRES_DB=synapse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://synapse:synapse@localhost:5432/synapse?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- API service ---
API_PORT=4000
API_URL=http://localhost:4000

# --- Collab (WebSocket) service ---
COLLAB_PORT=4001

# --- Web frontend ---
WEB_PORT=5173
VITE_API_URL=http://localhost:4000
VITE_COLLAB_URL=ws://localhost:4001

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Optional Google OAuth (Phase 0 stretch)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI (Gemini) ---
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embeddings — uses Gemini gemini-embedding-001 (free, 768-dim) by default.
# Set to "stub" with no API key to use deterministic hash-based vectors in dev.
EMBEDDINGS_PROVIDER=gemini
EMBEDDINGS_MODEL=gemini-embedding-001
EMBEDDINGS_DIM=768
