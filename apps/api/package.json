    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.20.0",
    "@synapse/shared": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
